{
  "name": "markets-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "graphql-codegen --config codegen.ts && git diff --exit-code graphql/generated/",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "cd .. && husky markets-app/.husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@gluestack-ui/nativewind-utils": "^1.0.28",
    "@gluestack-ui/overlay": "^0.1.22",
    "@gluestack-ui/toast": "^1.0.9",
    "@gluestack-ui/tooltip": "^0.1.44",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.33",
    "@shopify/flash-list": "2.0.2",
    "expo": "55.0.10-canary-20260328-bdc6273",
    "expo-apple-authentication": "^55.0.9",
    "expo-auth-session": "^55.0.10",
    "expo-constants": "55.0.10-canary-20260328-bdc6273",
    "expo-crypto": "^55.0.10",
    "expo-font": "55.0.5-canary-20260328-bdc6273",
    "expo-image": "55.0.7-canary-20260328-bdc6273",
    "expo-linking": "55.0.10-canary-20260328-bdc6273",
    "expo-location": "55.1.5-canary-20260328-bdc6273",
    "expo-notifications": "55.0.15-canary-20260328-bdc6273",
    "expo-router": "55.0.9-canary-20260328-bdc6273",
    "expo-secure-store": "55.0.10-canary-20260328-bdc6273",
    "expo-splash-screen": "55.0.14-canary-20260328-bdc6273",
    "expo-status-bar": "55.0.5-canary-20260328-bdc6273",
    "expo-symbols": "55.0.6-canary-20260328-bdc6273",
    "expo-web-browser": "55.0.11-canary-20260328-bdc6273",
    "graphql": "^16.13.2",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-mmkv": "^4.3.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "rxjs": "^7.8.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
