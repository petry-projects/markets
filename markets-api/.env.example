# Markets API — Environment Variables
# Copy to .env and fill in values for local development.

# Required — PostgreSQL connection string
DATABASE_URL=postgres://markets:markets_dev@localhost:5432/markets_dev?sslmode=disable

# Optional — path to Firebase service account JSON key
# Leave empty to run without auth (dev mode only)
FIREBASE_CREDENTIALS=

# Optional — HTTP server port (default: 8080)
PORT=8080

# Optional — environment name: development | staging | production
# "development" enables graceful Firebase degradation
ENVIRONMENT=development

# Integration tests — separate database to avoid polluting dev data
TEST_DATABASE_URL=postgres://markets:markets_dev@localhost:5432/markets_test?sslmode=disable
