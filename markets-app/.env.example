# Markets App — Environment Variables
# Copy to .env and fill in values for local development.

# API endpoint
EXPO_PUBLIC_API_URL=http://localhost:8080/query

# Firebase — get values from Firebase Console → Project Settings
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# Google OAuth — get Web Client ID from Firebase Console → Authentication → Google provider
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Facebook OAuth — get App ID from Facebook Developer Console
EXPO_PUBLIC_FACEBOOK_APP_ID=

# UAT bypass for local web development (disable for real auth testing)
EXPO_PUBLIC_UAT_BYPASS_AUTH=false
